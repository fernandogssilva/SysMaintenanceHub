<Window x:Class="SysMaintenanceHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SysMaintenanceHub.ViewModels"
        xmlns:conv="clr-namespace:SysMaintenanceHub.Converters"
        xmlns:models="clr-namespace:SysMaintenanceHub.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SysMaintenanceHub — Manutenção e Atualizações"
        Height="820" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Bg0Brush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="B2V"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
        <conv:MegabytesFormatConverter x:Key="MbFmt"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Progress -->
            <RowDefinition Height="Auto"/>  <!-- KPI cards -->
            <RowDefinition Height="*"/>     <!-- Main tabs -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18" Background="{DynamicResource Bg1Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Spinner -->
                <Canvas Grid.Column="0" Width="42" Height="42" Margin="0,0,14,0">
                    <Ellipse Width="42" Height="42" Stroke="{DynamicResource Bg3Brush}" StrokeThickness="4"/>
                    <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="4"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 21 3 A 18 18 0 0 1 39 21"
                          RenderTransformOrigin="0.5,0.5"
                          Visibility="{Binding IsBusy, Converter={StaticResource B2V}}">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinT" Angle="0" CenterX="21" CenterY="21"/>
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Path.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SpinT"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.1"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                    <Ellipse Width="14" Height="14" Canvas.Left="14" Canvas.Top="14"
                             Fill="{DynamicResource AccentBrush}"
                             Visibility="{Binding IsBusy, Converter={StaticResource B2V}, ConverterParameter=inv}"/>
                </Canvas>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="SysMaintenanceHub" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource Fg0Brush}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="13"
                               Foreground="{DynamicResource Fg2Brush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚡ Executar tudo" Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunFullMaintenanceCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                            Margin="0,0,8,0"/>
                    <Button Content="↻ Atualizar" Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshAllCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                            Margin="0,0,8,0"/>
                    <Button Content="✕ Cancelar" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsBusy}"
                            Margin="0,0,8,0"/>
                    <Button Content="🌓 Tema" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleThemeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1" Height="4"
                     Value="{Binding Progress, Mode=OneWay}"
                     IsIndeterminate="{Binding IsIndeterminate}"
                     Maximum="100" Minimum="0"/>

        <!-- KPI cards -->
        <Grid Grid.Row="2" Margin="18,18,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Windows Update" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding PendingWindowsUpdates}" Style="{StaticResource CardValue}"/>
                    <TextBlock Text="atualizações pendentes" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Segurança" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding PendingSecurityUpdates}" Style="{StaticResource CardValue}"
                               Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="KBs de segurança" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Aplicativos (winget)" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding PendingApps}" Style="{StaticResource CardValue}"/>
                    <TextBlock Text="apps com update disponível" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Limpeza estimada" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding TotalCleanableMB, Converter={StaticResource MbFmt}}"
                               Style="{StaticResource CardValue}"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding LastCleanupText, StringFormat='última limpeza: {0}'}"
                               Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Startup" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding StartupAppCount}" Style="{StaticResource CardValue}"/>
                    <TextBlock Text="apps na inicialização" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="5" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Fragmentação" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding DriveInfoText}" Style="{StaticResource CardCaption}"
                               FontSize="13" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main tabs -->
        <TabControl Grid.Row="3" Margin="18,18,18,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource Fg1Brush}">

            <TabItem Header="Windows Update">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Instalar todos" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding InstallWindowsUpdatesCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding WindowsUpdates}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="KB"        Binding="{Binding Kb}"       Width="120"/>
                            <DataGridTextColumn Header="Título"    Binding="{Binding Title}"    Width="*"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="220"/>
                            <DataGridTextColumn Header="Tamanho (MB)" Binding="{Binding SizeMB, StringFormat={}{0:N1}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Aplicativos (winget)">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Atualizar tudo" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding UpgradeAppsCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding WingetUpdates}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome"    Binding="{Binding Name}"             Width="*"/>
                            <DataGridTextColumn Header="Id"      Binding="{Binding Id}"               Width="260"/>
                            <DataGridTextColumn Header="Atual"   Binding="{Binding CurrentVersion}"   Width="140"/>
                            <DataGridTextColumn Header="Disponível" Binding="{Binding AvailableVersion}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Limpeza">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Executar limpeza + Disk Cleanup" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding RunCleanupCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Cleanables}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Name}"    Width="220"/>
                            <DataGridTextColumn Header="Caminho"   Binding="{Binding Path}"    Width="*"/>
                            <DataGridTextColumn Header="Tamanho"   Binding="{Binding SizeMB, StringFormat={}{0:N1} MB}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Startup">
                <DataGrid Margin="0,10,0,0" ItemsSource="{Binding StartupApps}"
                          AutoGenerateColumns="False" HeadersVisibility="Column"
                          CanUserAddRows="False" GridLinesVisibility="None"
                          Background="{DynamicResource Bg1Brush}"
                          RowBackground="{DynamicResource Bg1Brush}"
                          AlternatingRowBackground="{DynamicResource Bg2Brush}"
                          Foreground="{DynamicResource Fg1Brush}"
                          BorderThickness="0" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nome"     Binding="{Binding Name}"     Width="260"/>
                        <DataGridTextColumn Header="Local"    Binding="{Binding Location}" Width="160"/>
                        <DataGridTextColumn Header="Comando"  Binding="{Binding Command}"  Width="*"/>
                        <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Enabled}" Width="70"/>
                        <DataGridTemplateColumn Header="Ação" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Alternar" Style="{StaticResource SecondaryButton}"
                                            Padding="10,4"
                                            Command="{Binding DataContext.ToggleStartupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Discos">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Otimizar/Desfragmentar" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding DefragAllCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Drives}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Drive"           Binding="{Binding Drive}"                                          Width="80"/>
                            <DataGridTextColumn Header="Fragmentação (%)" Binding="{Binding FragmentationPercent, StringFormat={}{0:N0}}"  Width="160"/>
                            <DataGridTextColumn Header="Último defrag"    Binding="{Binding LastDefrag, StringFormat={}{0:dd/MM/yyyy}}"    Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Abrir pasta de logs" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding OpenLogsFolderCommand}"/>
                    <Border Grid.Row="1" Background="{DynamicResource LogBgBrush}"
                            BorderBrush="{DynamicResource Bg3Brush}" BorderThickness="1" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12" x:Name="LogScroll">
                            <ItemsControl ItemsSource="{Binding LogLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="11.5" Foreground="{DynamicResource Fg2Brush}"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="4" Background="{DynamicResource Bg1Brush}" Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Fg2Brush}" FontSize="12"/>
                <TextBlock Grid.Column="1" Foreground="{DynamicResource Fg3Brush}" FontSize="11"
                           Text="SysMaintenanceHub · v1.0 · DataSec"/>
            </Grid>
        </Border>
    </Grid>
</Window>
