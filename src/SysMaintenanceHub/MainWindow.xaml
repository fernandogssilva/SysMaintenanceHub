<Window x:Class="SysMaintenanceHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SysMaintenanceHub.ViewModels"
        xmlns:conv="clr-namespace:SysMaintenanceHub.Converters"
        xmlns:models="clr-namespace:SysMaintenanceHub.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Wintal — A saúde do seu Windows"
        Icon="Assets/Wintal.ico"
        Height="820" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Bg0Brush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="B2V"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
        <conv:MegabytesFormatConverter x:Key="MbFmt"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0 Header -->
            <RowDefinition Height="Auto"/>  <!-- 1 Progress -->
            <RowDefinition Height="Auto"/>  <!-- 2 KPI cards -->
            <RowDefinition Height="Auto"/>  <!-- 3 Catálogo Microsoft -->
            <RowDefinition Height="*"/>     <!-- 4 Main tabs -->
            <RowDefinition Height="Auto"/>  <!-- 5 Footer -->
            <RowDefinition Height="0"/>     <!-- 6 reservado -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18" Background="{DynamicResource Bg1Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Spinner -->
                <Canvas Grid.Column="0" Width="42" Height="42" Margin="0,0,14,0">
                    <Ellipse Width="42" Height="42" Stroke="{DynamicResource Bg3Brush}" StrokeThickness="4"/>
                    <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="4"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 21 3 A 18 18 0 0 1 39 21"
                          RenderTransformOrigin="0.5,0.5"
                          Visibility="{Binding IsBusy, Converter={StaticResource B2V}}">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinT" Angle="0" CenterX="21" CenterY="21"/>
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Path.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SpinT"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.1"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                    <Path Data="M 12 21 L 19 28 L 32 15" Stroke="{DynamicResource SuccessBrush}"
                          StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Visibility="{Binding IsBusy, Converter={StaticResource B2V}, ConverterParameter=inv}"/>
                </Canvas>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Wintal" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource Fg0Brush}"/>
                        <TextBlock Text="a saúde do seu Windows" FontSize="13"
                                   Foreground="{DynamicResource Fg2Brush}"
                                   Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                               Foreground="{DynamicResource Fg3Brush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚡ Executar tudo" Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunFullMaintenanceCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                            Margin="0,0,8,0"/>
                    <Button Content="↻ Atualizar" Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshAllCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                            Margin="0,0,8,0"/>
                    <Button Content="✕ Cancelar" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsBusy}"
                            Margin="0,0,8,0"/>
                    <Button Content="🌓 Tema" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleThemeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1" Height="4"
                     Value="{Binding Progress, Mode=OneWay}"
                     IsIndeterminate="{Binding IsIndeterminate}"
                     Maximum="100" Minimum="0"/>

        <!-- KPI cards -->
        <Grid Grid.Row="2" Margin="18,18,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Windows Update" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding PendingWindowsUpdates}" Style="{StaticResource CardValue}"/>
                    <TextBlock Text="atualizações pendentes" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Segurança" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding PendingSecurityUpdates}" Style="{StaticResource CardValue}"
                               Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="KBs de segurança" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Aplicativos (winget)" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding PendingApps}" Style="{StaticResource CardValue}"/>
                    <TextBlock Text="apps com update disponível" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Limpeza estimada" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding TotalCleanableMB, Converter={StaticResource MbFmt}}"
                               Style="{StaticResource CardValue}"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding LastCleanupText, StringFormat='última limpeza: {0}'}"
                               Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Startup" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding StartupAppCount}" Style="{StaticResource CardValue}"/>
                    <TextBlock Text="apps na inicialização" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="5" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Vulnerabilidades" Style="{StaticResource CardTitle}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CriticalVulnCount}" Style="{StaticResource CardValue}"
                                   Foreground="{DynamicResource DangerBrush}"/>
                        <TextBlock Text="{Binding TotalVulnCount, StringFormat=' / {0}'}"
                                   Style="{StaticResource CardValue}"
                                   FontSize="18" VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource Fg2Brush}"/>
                    </StackPanel>
                    <TextBlock Text="críticas / total (MSRC)" Style="{StaticResource CardCaption}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 3: Catálogo Microsoft -->
        <Border Grid.Row="3" Margin="18,12,18,0" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="12" Height="12" Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CatalogHasPending}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Catálogo Microsoft (release-health)" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="{Binding CatalogStatus}" Style="{StaticResource CardCaption}"
                               FontSize="12.5" Margin="0,4,0,0"/>
                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource Fg3Brush}">
                        <Run Text="Local:"/>
                        <Run Text="{Binding CurrentOsBuild}"/>
                        <Run Text=" · Oficial:"/>
                        <Run Text="{Binding LatestOfficialKb}"/>
                        <Run Text="("/><Run Text="{Binding LatestOfficialBuild}"/><Run Text=")"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="2" Content="Verificar catálogo agora"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CheckMicrosoftCatalogCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                        Margin="8,0,8,0" VerticalAlignment="Center"/>
                <Button Grid.Column="3" Content="Instalar pendentes"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding InstallWindowsUpdatesCommand}"
                        IsEnabled="{Binding CatalogHasPending}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main tabs -->
        <TabControl Grid.Row="4" Margin="18,18,18,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource Fg1Brush}">

            <TabItem Header="Windows Update">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Instalar todos" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding InstallWindowsUpdatesCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding WindowsUpdates}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              EnableRowVirtualization="True" EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="KB"        Binding="{Binding Kb}"       Width="120"/>
                            <DataGridTextColumn Header="Título"    Binding="{Binding Title}"    Width="*"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="220"/>
                            <DataGridTextColumn Header="Tamanho (MB)" Binding="{Binding SizeMB, StringFormat={}{0:N1}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Atualizações pendentes">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Atualizar tudo" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding UpgradeAppsCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding WingetUpdates}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome"    Binding="{Binding Name}"             Width="*"/>
                            <DataGridTextColumn Header="Id"      Binding="{Binding Id}"               Width="260"/>
                            <DataGridTextColumn Header="Atual"   Binding="{Binding CurrentVersion}"   Width="140"/>
                            <DataGridTextColumn Header="Disponível" Binding="{Binding AvailableVersion}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Limpeza">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Executar limpeza + Disk Cleanup" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding RunCleanupCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Cleanables}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Name}"    Width="220"/>
                            <DataGridTextColumn Header="Caminho"   Binding="{Binding Path}"    Width="*"/>
                            <DataGridTextColumn Header="Tamanho"   Binding="{Binding SizeMB, StringFormat={}{0:N1} MB}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Startup">
                <DataGrid Margin="0,10,0,0" ItemsSource="{Binding StartupApps}"
                          AutoGenerateColumns="False" HeadersVisibility="Column"
                          CanUserAddRows="False" GridLinesVisibility="None"
                          Background="{DynamicResource Bg1Brush}"
                          RowBackground="{DynamicResource Bg1Brush}"
                          AlternatingRowBackground="{DynamicResource Bg2Brush}"
                          Foreground="{DynamicResource Fg1Brush}"
                          BorderThickness="0" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nome"     Binding="{Binding Name}"     Width="260"/>
                        <DataGridTextColumn Header="Local"    Binding="{Binding Location}" Width="160"/>
                        <DataGridTextColumn Header="Comando"  Binding="{Binding Command}"  Width="*"/>
                        <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Enabled}" Width="70"/>
                        <DataGridTemplateColumn Header="Ação" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Alternar" Style="{StaticResource SecondaryButton}"
                                            Padding="10,4"
                                            Command="{Binding DataContext.ToggleStartupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Discos">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Otimizar/Desfragmentar" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding DefragAllCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Drives}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Drive"           Binding="{Binding Drive}"                                          Width="80"/>
                            <DataGridTextColumn Header="Fragmentação (%)" Binding="{Binding FragmentationPercent, StringFormat={}{0:N0}}"  Width="160"/>
                            <DataGridTextColumn Header="Último defrag"    Binding="{Binding LastDefrag, StringFormat={}{0:dd/MM/yyyy}}"    Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Vulnerabilidades">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Varrer MSRC agora" Style="{StaticResource PrimaryButton}"
                                Command="{Binding RunVulnScanCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Foreground="{DynamicResource Fg2Brush}" FontSize="12" Margin="0,0,0,8">
                        <Run Text="Fonte: MSRC CVRF API — https://api.msrc.microsoft.com/cvrf/v3.0"/>
                        <LineBreak/>
                        <Run Text="Status:"/><Run Text="{Binding VulnScanStatus}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Vulnerabilities}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Severidade" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource Bg3Brush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Important">
                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Moderate">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Severity}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="CVSS"  Binding="{Binding CvssScore, StringFormat={}{0:N1}}" Width="70"/>
                            <DataGridTextColumn Header="CVE"   Binding="{Binding Cve}"                              Width="140"/>
                            <DataGridTextColumn Header="KB"    Binding="{Binding Kb}"                               Width="110"/>
                            <DataGridTextColumn Header="Título" Binding="{Binding Title}"                           Width="*"/>
                            <DataGridTextColumn Header="Publicado" Binding="{Binding ReleaseDate, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                            <DataGridTemplateColumn Header="Ações" Width="280">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Aplicar patch" Style="{StaticResource PrimaryButton}"
                                                    Padding="10,4" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.ApplyPatchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="MSRC" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.OpenCatalogUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding MsrcUrl}"/>
                                            <Button Content="Catálogo" Style="{StaticResource SecondaryButton}" Padding="10,4"
                                                    Command="{Binding DataContext.OpenCatalogUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding CatalogUrl}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Catálogo Microsoft">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Consultar catálogo agora" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CheckMicrosoftCatalogCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}" Margin="0,0,8,0"/>
                        <Button Content="Instalar pendentes" Style="{StaticResource SecondaryButton}"
                                Command="{Binding InstallWindowsUpdatesCommand}"
                                IsEnabled="{Binding CatalogHasPending}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Margin="0,0,0,8" Foreground="{DynamicResource Fg2Brush}" FontSize="12">
                        <Run Text="Comparação: sua build"/>
                        <Run Text="{Binding CurrentOsBuild}" FontWeight="SemiBold"/>
                        <Run Text=" vs. última publicada pela Microsoft (KB"/>
                        <Run Text="{Binding LatestOfficialKb}"/>
                        <Run Text=", build"/>
                        <Run Text="{Binding LatestOfficialBuild}"/>
                        <Run Text=")."/>
                    </TextBlock>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding CatalogPending}"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              CanUserAddRows="False" GridLinesVisibility="None"
                              Background="{DynamicResource Bg1Brush}"
                              RowBackground="{DynamicResource Bg1Brush}"
                              AlternatingRowBackground="{DynamicResource Bg2Brush}"
                              Foreground="{DynamicResource Fg1Brush}"
                              BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="KB"         Binding="{Binding Kb}"            Width="120"/>
                            <DataGridTextColumn Header="Build"      Binding="{Binding BuildString}"   Width="120"/>
                            <DataGridTextColumn Header="Publicado"  Binding="{Binding PublishedAt, StringFormat={}{0:dd/MM/yyyy}}" Width="120"/>
                            <DataGridTemplateColumn Header="Catálogo (Microsoft)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Abrir no site da Microsoft"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="10,4" HorizontalAlignment="Left"
                                                Command="{Binding DataContext.OpenCatalogUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding CatalogUrl}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Abrir pasta de logs" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Command="{Binding OpenLogsFolderCommand}"/>
                    <Border Grid.Row="1" Background="{DynamicResource LogBgBrush}"
                            BorderBrush="{DynamicResource Bg3Brush}" BorderThickness="1" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12" x:Name="LogScroll">
                            <ItemsControl ItemsSource="{Binding LogLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="11.5" Foreground="{DynamicResource Fg2Brush}"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="5" Background="{DynamicResource Bg1Brush}" Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Fg2Brush}" FontSize="12"/>
                <TextBlock Grid.Column="1" Foreground="{DynamicResource Fg3Brush}" FontSize="11"
                           Text="Wintal · v1.4 · by DataSec"/>
            </Grid>
        </Border>
    </Grid>
</Window>
